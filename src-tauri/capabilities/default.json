{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "log:default",
    "fs:default",
    {
      "identifier": "fs:allow-copy-file",
			"allow": [
				{
					"path": "$APPDATA/*"
				},
				{
					"path": "$APPDATA/**"
				}
			]
    },
    {
      "identifier": "fs:allow-exists",
			"allow": [
				{
					"path": "$APPDATA/*"
				},
				{
					"path": "$APPDATA/**"
				}
			]
    },
    {
      "identifier": "fs:allow-read-text-file",
			"allow": [
				{
					"path": "$APPDATA/*"
				},
				{
					"path": "$APPDATA/**"
				}
			]
    },
    {
      "identifier": "fs:allow-write-text-file",
			"allow": [
				{
					"path": "$APPDATA/*"
				},
				{
					"path": "$APPDATA/**"
				}
			]
    },
    {
      "identifier": "fs:allow-mkdir",
			"allow": [
				{
					"path": "$APPDATA"
				},
				{
					"path": "$APPDATA/*"
				},
				{
					"path": "$APPDATA/**"
				}
			]
    },
    {
      "identifier": "fs:allow-read-dir",
			"allow": [
				{
					"path": "$APPDATA"
				},
				{
					"path": "$APPDATA/*"
				},
				{
					"path": "$APPDATA/**"
				}
			]
    },
    {
      "identifier": "fs:allow-rename",
			"allow": [
				{
					"path": "$APPDATA/*"
				},
				{
					"path": "$APPDATA/**"
				}
			]
    },
    {
      "identifier": "fs:allow-remove",
			"allow": [
				{
					"path": "$APPDATA/*"
				},
				{
					"path": "$APPDATA/**"
				}
			]
		},
		{
			"identifier": "http:default",
			"allow": [
				{
					"url": "http://*"
				},
				{
					"url": "https://*"
				},
				{
					"url": "http://*:*"
				},
				{
					"url": "https://*:*"
				}
		  ]
		},
    "sql:default",
    "sql:allow-execute",
    "os:default",
    "dialog:allow-save",
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$APPDATA/*" },
        { "path": "$APPDATA/**" },
        { "path": "$HOME/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENTS/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$APPDATA/*" },
        { "path": "$APPDATA/**" },
        { "path": "$HOME/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENTS/**" }
      ]
    }
  ]
}
